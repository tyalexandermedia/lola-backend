# ── Google APIs (all free tier) ──────────────────────────────────
# PageSpeed Insights — free, no daily limit
GOOGLE_PAGESPEED_API_KEY=your_key_here

# Google Places API — $200/mo free credit (~6,700 searches)
GOOGLE_PLACES_API_KEY=your_key_here

# Google Safe Browsing API — free
GOOGLE_SAFE_BROWSING_API_KEY=your_key_here

# Google Custom Search API — 100 queries/day free
GOOGLE_CUSTOM_SEARCH_API_KEY=your_key_here
GOOGLE_CUSTOM_SEARCH_CX=your_cx_id_here

# ── Automation ────────────────────────────────────────────────────
# Make.com (Integromat) — paste your webhook URL from scenario
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your_webhook_id

# ── Admin ─────────────────────────────────────────────────────────
# Any random string — used for GET /leads admin endpoint
LOLA_SECRET_ADMIN_KEY=change_me_to_something_random

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://lola-seo.vercel.app,https://links.tyalexandermedia.com,http://localhost:3000,http://localhost:5173

