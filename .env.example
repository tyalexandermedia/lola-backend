# ── Google APIs (all free tier) ──────────────────────────────────
# PageSpeed Insights — free, no daily limit
GOOGLE_PAGESPEED_API_KEY=your_key_here

# Google Places API — $200/mo free credit (~6,700 searches)
GOOGLE_PLACES_API_KEY=your_key_here

# Google Safe Browsing API — free
GOOGLE_SAFE_BROWSING_API_KEY=your_key_here

# Google Custom Search API — 100 queries/day free
GOOGLE_CUSTOM_SEARCH_API_KEY=your_key_here
GOOGLE_CUSTOM_SEARCH_CX=your_cx_id_here

# ── Admin ─────────────────────────────────────────────────────────
# Any random string — used for GET /leads admin endpoint
LOLA_SECRET_ADMIN_KEY=change_me_to_something_random

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://lola.tyalexandermedia.com,https://links.tyalexandermedia.com,http://localhost:3000,http://localhost:5173

# ── Brevo (CRM) ───────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
BREVO_LIST_ID=2

# ── Resend (audit-result email) ───────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
AUDIT_FROM_EMAIL=Coach Ty (Lola) <ty@tyalexandermedia.com>
AUDIT_REPLY_TO_EMAIL=ty@tyalexandermedia.com

# Stripe Payment Links used in the audit-confirmation email upsell.
# Mirror VITE_STRIPE_*_URL on the frontend. Defaults in code are live URLs.
STRIPE_DIY_URL=https://buy.stripe.com/14A7sK65YaJ127fg5P3oA09
STRIPE_SPRINT_URL=https://buy.stripe.com/aFabJ00LEdVd3bj3j33oA07
STRIPE_RETAINER_URL=https://buy.stripe.com/7sY7sK2TMdVd13b4n73oA08

# Stripe API secret + webhook signing secret. Power server-side verification
# of Checkout Sessions (so /diy can't be unlocked by guessing a URL param) and
# fulfillment on payment. Both optional — unset means /checkout/verify reports
# "unconfigured" (frontend stays locked) and /stripe/webhook 200s as a no-op.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Amount (in cents) each Payment Link charges → maps a paid session to a tier.
STRIPE_DIY_AMOUNT=19700
STRIPE_BUILD_AMOUNT=99700

# Public URL of the deployed frontend. Used to build shareable report
# links (`/r/<audit_id>`) that the Resend email points to.
PUBLIC_APP_URL=https://lola.tyalexandermedia.com

# ── Frontend env (Vercel) — set as Vite vars in Vercel dashboard ──
# Stripe Payment Links — 4 tiers. All reset to placeholders on 2026-05-23
# because pricing changed (DIY $47, Sprint $397, Retainer $697/mo,
# Pro $6,970/yr). Create new Stripe Payment Links + paste real URLs here.
VITE_STRIPE_DIY_PDF_URL=https://buy.stripe.com/14A7sK65YaJ127fg5P3oA09
VITE_STRIPE_SPRINT_URL=https://buy.stripe.com/aFabJ00LEdVd3bj3j33oA07
VITE_STRIPE_RETAINER_MONTHLY_URL=https://buy.stripe.com/7sY7sK2TMdVd13b4n73oA08
VITE_STRIPE_PRO_URL=https://buy.stripe.com/eVq14mfGydVd9zH2eZ3oA06
# ── Booking: ONE calendar link for every "book a call" CTA site-wide ──
# All call CTAs use VITE_CALENDAR_URL (Google Calendar). Pay CTAs use the
# Stripe links above. Keep this the single source so the funnel is consistent.
VITE_CALENDAR_URL=https://calendar.app.google/J7idjUDitd2Hziuc7
# (Deprecated) VITE_STRATEGY_CALL_URL is no longer read — left blank so an old
# cal.com value can't split the funnel. Delete it from your Vercel env too.
VITE_STRATEGY_CALL_URL=
# Auto-Fix snippet endpoint (Pro tier infrastructure — Week 2-3-4)
VITE_AUTOFIX_API_URL=https://api.lola-seo.com/autofix

# ── PostHog (product analytics + heatmaps + session recording + A/B) ──
# Live Project API key baked into src/analytics.ts as default (it's public-safe).
# Only set this env var to point a staging/preview deploy at a different
# PostHog project. US-cloud host unless your project lives in EU.
VITE_POSTHOG_KEY=phc_wSpZvSfqfZ9dLxujkupapvEbZyqLLQ5T6MZaBSd2XTXn
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Cold outreach (Agent 4) ───────────────────────────────────────
OUTREACH_FROM_EMAIL=LOLA SEO <lola@tyalexandermedia.com>
# ISO date — drives the 10/25/50 daily-cap ramp.
OUTREACH_LAUNCH_DATE=2026-05-22
# Optional override (skip the ramp during testing).
# OUTREACH_DAILY_CAP_OVERRIDE=5
OUTREACH_JITTER_MIN_SEC=30
OUTREACH_JITTER_MAX_SEC=90

# ── Tier 2: Resend event webhook (opens/clicks/bounces/complaints) ──
# Configure Resend → Webhooks → add `https://<your-backend>/webhooks/resend`.
# Resend gives you a signing secret that starts with `whsec_`. Paste it here
# so signatures are verified. Leave empty in local dev to skip verification.
RESEND_WEBHOOK_SECRET=

# ── Tier 3: LLM-generated per-lead variants (optional) ─────────────
# Set to `true` to enable. Falls back to static templates whenever the API
# key is missing, the call fails, or the JSON shape is wrong.
OUTREACH_LLM_VARIANTS=false
ANTHROPIC_API_KEY=
# Override the default model if you want to test against another tier.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AI visibility tracking providers (optional) ─────────────────
# Case-study/client snapshots use whichever keys are present. Missing keys
# simply skip that provider for the run.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar-pro
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ── Tier 4: Reply auto-suppress webhook ────────────────────────────
# Set OUTREACH_REPLY_DOMAIN to enable per-lead Reply-To aliases like
# `reply+<token>@reply.yourdomain.com`. Without it, replies still come back
# to OUTREACH_FROM_EMAIL and you mark them manually via:
#   python -m outreach.cli suppress --email foo@bar.com --reason replied
OUTREACH_REPLY_DOMAIN=
# Shared secret for /webhooks/reply. Your inbound-mail provider (Cloudflare
# Email Routing / Mailgun / etc.) sends this in the X-Reply-Webhook-Secret
# header.
REPLY_WEBHOOK_SECRET=

# ── Audit cost guardrails ─────────────────────────────────────────
# Max outbound API calls per audit run. Default 6 covers 1 PSI + 2 Places +
# 1 SafeBrowsing + 1 CustomSearch with 1 slot of headroom.
AUDIT_API_BUDGET=6
# Per-call timeout for outbound APIs, in seconds (PageSpeed gets 2× this).
API_TIMEOUT=8.0

# ── Reviews module ────────────────────────────────────────────────
# Customer review-capture flow. Admin creates businesses + sends requests
# via POST /reviews/* (auth: LOLA_SECRET_ADMIN_KEY). Customer-facing
# feedback page lives at <REVIEWS_PUBLIC_BASE_URL>/lp/feedback?id=<request_id>.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
REVIEWS_PUBLIC_BASE_URL=https://lola.tyalexandermedia.com

# ── Stripe Payment Links — CURRENT two-tier model (pay-now → access) ──
# These power the pay-now CTAs on /pricing, /retainer, /diy, and /build/start.
# Use the SAME two Payment Links the backend audit email already uses:
#   VITE_STRIPE_DIY_URL   = the $197 DIY link   (backend STRIPE_SPRINT_URL)
#   VITE_STRIPE_BUILD_URL = the $997 Build link (backend STRIPE_RETAINER_URL)
# In the Stripe dashboard, set each link's success redirect to its access page:
#   DIY   → https://lola.tyalexandermedia.com/diy?session_id={CHECKOUT_SESSION_ID}
#   Build → https://lola.tyalexandermedia.com/build/start?session_id={CHECKOUT_SESSION_ID}
# (These supersede the deprecated VITE_STRIPE_*_PDF/SPRINT/RETAINER/PRO placeholders above.)
VITE_STRIPE_DIY_URL=
VITE_STRIPE_BUILD_URL=

# ── Growth Score follow-up sequence (turns free scores into buyers) ──
# A background runner nurtures every Growth Score lead: nudge (~24h) →
# Half-Back Guarantee (~72h) → final email (~7d, quietly offers the optional
# $299/mo). Uses Resend for email + Twilio for SMS (only if the lead consented;
# "Reply STOP to opt out." is always appended). The $299/mo is EMAIL-ONLY.
#
# SAFE BY DEFAULT: the runner is dormant until Resend or Twilio is configured,
# and it only ever touches leads enrolled AFTER deploy — turning it on never
# retro-blasts old contacts. Buyers are auto-suppressed via the Stripe webhook.
# Admin: GET /followups/stats and POST /followups/run (X-Admin-Key header).
FOLLOWUP_ENABLED=true
# Delay before the first touch, then the gaps between touches (hours).
FOLLOWUP_STEP1_HOURS=24
FOLLOWUP_STEP2_GAP_HOURS=48
FOLLOWUP_STEP3_GAP_HOURS=96
# How often the runner scans for due follow-ups (seconds).
FOLLOWUP_SCAN_SECONDS=900
# Booking link used in follow-up CTAs (defaults to the Google Calendar link).
FOLLOWUP_CALL_URL=https://calendar.app.google/J7idjUDitd2Hziuc7

# ── Post-build → recurring: the LTV engine ──────────────────────────────────
# When someone buys the $997 Full Build, they enter a SECOND sequence that
# pitches the monthly "Lola Managed" continuity (keeps them ranked + in AI
# answers, review engine, GBP posts, lead follow-up). Timed to land as their
# 30-day build window closes. This is where lifetime value compounds.
FOLLOWUP_MANAGED_PRICE=$297/mo
# Stripe SUBSCRIPTION Payment Link for Lola Managed. Until set, the CTA falls
# back to the booking link (FOLLOWUP_CALL_URL) so you can close it on a call.
FOLLOWUP_MANAGED_URL=
# Cadence (days): first touch near the end of the 30-day window, then follow-ups.
FOLLOWUP_BUILD_STEP1_DAYS=25
FOLLOWUP_BUILD_GAP12_DAYS=7
FOLLOWUP_BUILD_GAP23_DAYS=14
